options -indexes
RewriteEngine on

# Habilitar o PHP 5.5
AddHandler application/x-httpd-php55 .php

<IfModule mod_security.c>
	SecFilterEngine off
	SecFilterScanPOST off
</IfModule>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^(.*)$	index.php?p=$1 [QSA] 	 	 